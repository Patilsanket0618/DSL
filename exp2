#include <iostream>
using namespace std;

int main() {
    int a[10][10], b[10][10], result[10][10];
    int r1, c1, r2, c2, i, j, k, choice;

    cout << "Enter rows and columns of Matrix A: ";
    cin >> r1 >> c1;

    cout << "Enter elements of Matrix A:\n";
    for(i = 0; i < r1; i++)
        for(j = 0; j < c1; j++)
            cin >> a[i][j];

    cout << "Enter rows and columns of Matrix B: ";
    cin >> r2 >> c2;

    cout << "Enter elements of Matrix B:\n";
    for(i = 0; i < r2; i++)
        for(j = 0; j < c2; j++)
            cin >> b[i][j];

    do {
        cout << "\n--- Matrix Operations Menu ---\n";
        cout << "1. Addition\n";
        cout << "2. Subtraction\n";
        cout << "3. Multiplication\n";
        cout << "4. Transpose of Matrix A\n";
        cout << "5. Exit\n";
        cout << "Enter your choice: ";
        cin >> choice;

        switch(choice) {

            case 1: // Addition
                if(r1 == r2 && c1 == c2) {
                    for(i = 0; i < r1; i++) {
                        for(j = 0; j < c1; j++) {
                            result[i][j] = a[i][j] + b[i][j];
                            cout << result[i][j] << " ";
                        }
                        cout << endl;
                    }
                } else {
                    cout << "Addition not possible!\n";
                }
                break;

            case 2: // Subtraction
                if(r1 == r2 && c1 == c2) {
                    for(i = 0; i < r1; i++) {
                        for(j = 0; j < c1; j++) {
                            result[i][j] = a[i][j] - b[i][j];
                            cout << result[i][j] << " ";
                        }
                        cout << endl;
                    }
                } else {
                    cout << "Subtraction not possible!\n";
                }
                break;

            case 3: // Multiplication
                if(c1 == r2) {
                    for(i = 0; i < r1; i++) {
                        for(j = 0; j < c2; j++) {
                            result[i][j] = 0;
                            for(k = 0; k < c1; k++) {
                                result[i][j] += a[i][k] * b[k][j];
                            }
                            cout << result[i][j] << " ";
                        }
                        cout << endl;
                    }
                } else {
                    cout << "Multiplication not possible!\n";
                }
                break;

            case 4: // Transpose of Matrix A
                cout << "Transpose of Matrix A:\n";
                for(i = 0; i < c1; i++) {
                    for(j = 0; j < r1; j++) {
                        cout << a[j][i] << " ";
                    }
                    cout << endl;
                }
                break;

            case 5:
                cout << "Exiting...\n";
                break;

            default:
                cout << "Invalid choice!\n";
        }

    } while(choice != 5);

    return 0;
}
